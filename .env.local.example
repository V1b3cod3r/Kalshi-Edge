# Kalshi Edge — Environment Variables
# Copy this file to .env.local and fill in your values
# Note: API keys can also be configured via the Settings page in the UI
# and will be stored in data/settings.json

NEXT_PUBLIC_APP_NAME=Kalshi Edge

# Optional: Override API keys via environment variables instead of the UI
# ANTHROPIC_API_KEY=sk-ant-...
# KALSHI_API_KEY=...
