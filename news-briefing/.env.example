# Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Single password to gate the app. Pick something long.
APP_PASSWORD=change-me-to-a-long-random-string

# Used to sign the auth cookie. Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-32-byte-hex-string
